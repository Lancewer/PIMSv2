# Entry Input Skill 配置文件模板
# 此文件存放在 skill 目录下，首次 init 时会自动创建

# 数据目录（存放记录和附件）
raw_path: ~/PIMS_repo              # 支持 ~ 符号
                                  # 示例：~/Documents/PIMS_data

# Git 配置
git_auto_commit: true              # 每次变更自动 git commit
git_auto_push: false               # 是否自动推送远程仓库
git_remote_url: ''                 # 远程仓库地址
                                  # 示例: git@github.com:yourname/private-pims.git

# 备份配置
backup:
  enabled: true                    # 是否启用加密备份
  tool: restic                     # 备份工具：restic 或 borg
  repo_path: ~/PIMS_repo/backups   # 备份仓库路径
                                  # 默认在数据目录下的 backups 子目录
                                  # 或指定其他位置：/Volumes/Backup/pims-backups
  schedule: daily                  # 备份频率：daily 或 weekly

# 目录结构说明：
#
# 配置文件位置（skill 目录）：
# ~/.copaw/workspaces/personal_assistant/skills/entry_input/config.yaml
#
# 数据目录结构（raw_path）：
# ~/PIMS_repo/
# ├── .git/                        <- Git 仓库
# ├── raw/                         <- 记录数据
# │   └── 2026/
# │       └── 20260414/
# │           ├── 20260414.md
# │           ├── 20260414_120000.md
# │           └── attachment/
# └── backups/                     <- 备份仓库

# 使用说明：
# 1. 首次运行 python index.py init 时会创建此配置文件
# 2. 可直接编辑此文件修改配置
# 3. 所有路径支持 ~ 符号（用户主目录）
# 4. 修改 raw_path 后，需要在新位置重新 init